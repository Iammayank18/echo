{
  "name": "echo",
  "version": "1.0.0",
  "description": "AI-powered voice transcription for macOS - Open source alternative to Wispr Flow",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --mac --arm64 --x64", 
    "build:arm64": "electron-builder --mac --arm64",
    "build:x64": "electron-builder --mac --x64",
    "build:all": "electron-builder --mac --arm64 --x64",
    "pack": "electron-builder --mac --dir"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.echo.voice-ai",
    "productName": "Echo",
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dmg",
      "minimumSystemVersion": "10.15",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Echo needs microphone access to record voice for transcription.",
        "NSAccessibilityUsageDescription": "Echo needs accessibility access to paste transcribed text."
      }
    },
    "afterPack": "scripts/afterPack.js",
    "files": [
      "src/**/*"
    ],
    "npmRebuild": false,
    "extraFiles": [
      {
        "from": "src/fn-helper",
        "to": "Resources/fn-helper"
      },
      {
        "from": "assets/audio",
        "to": "Resources/audio"
      }
    ]
  },
  "dependencies": {
    "uiohook-napi": "^1.5.4"
  }
}
